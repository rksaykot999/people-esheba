# Server
PORT=5000
NODE_ENV=development

# Database — fill these in locally, NEVER commit real values here.
DB_HOST=your-db-host.example.com
DB_PORT=18004
DB_NAME=people_e_sheba
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT — generate a long random string, do not reuse this example.
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
